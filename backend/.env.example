# Copy this file to .env.local and fill in your values

# Database Configuration
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/research_assist

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# AWS Configuration
AWS_PROFILE=default
AWS_REGION=us-east-1

# AWS Bedrock Model IDs
BEDROCK_LLM_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# S3 Configuration
S3_BUCKET_NAME=your-bucket-name

# DynamoDB Configuration
DYNAMODB_CHAT_SESSIONS_TABLE=your-chat-sessions-table
DYNAMODB_CHAT_MESSAGES_TABLE=your-chat-messages-table

# Application Configuration
CONFIG_FILE=config.yaml
ENVIRONMENT=local
